---
import BaseLayout from '@/layouts/BaseLayout'
import { siteConfig } from '@/data/site.config'

type Props = {
	title: string
	description: string
	pubDate: string
	heroImage: string
	category: string
	readTime?: string
}

const { title, description, pubDate, heroImage, category, readTime } = Astro.props

const articleDate = new Date(pubDate).toISOString()

const authorName = siteConfig.author
const initials = authorName
	.split(' ')
	.map((n: string) => n[0])
	.join('')
	.toUpperCase()
	.slice(0, 2)

const readMinutes = readTime?.replace(' min read', '') ?? '?'
---

<BaseLayout title={title} description={description} image={heroImage} articleDate={articleDate}>
	<article class='min-w-full'>
		{
			heroImage && (
				<div class='-mx-5 sm:-mx-8 lg:-mx-0 overflow-hidden rounded-none lg:rounded-2xl mb-6'>
					<img
						src={heroImage}
						width='1200'
						height='500'
						loading='eager'
						class='w-full max-h-[340px] md:max-h-[480px] object-cover'
						alt={`img of ${title}`}
					/>
				</div>
			)
		}

		<h1 class='text-3xl md:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-4'>
			{title}
		</h1>

		<div class='flex items-center gap-3 mb-8 pb-6 border-b border-gray-200 dark:border-gray-700'>
			<div
				class='w-10 h-10 rounded-full bg-blue flex items-center justify-center text-white text-sm font-bold flex-shrink-0'
			>
				{initials}
			</div>
			<div class='flex flex-col'>
				<span class='font-semibold text-gray-900 dark:text-white text-sm'>By {authorName}</span>
				<span class='text-xs text-gray-500 dark:text-gray-400 capitalize'>{category}</span>
			</div>
			<div class='ml-auto flex items-center gap-1.5 text-gray-500 dark:text-gray-400 text-sm'>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					fill='none'
					viewBox='0 0 24 24'
					stroke-width='1.8'
					stroke='currentColor'
					class='w-4 h-4'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						d='M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z'></path>
				</svg>
				{readMinutes} min read
			</div>
		</div>

		<div class='prose prose-lg dark:prose-invert max-w-none mb-10'>
			<slot />
		</div>

		<div class='border-t border-b border-gray-200 dark:border-gray-700 py-5 my-8'>
			<slot name='share' />
		</div>

		<div class='mt-8'>
			<slot name='related' />
		</div>

		<div class='mt-8'>
			<slot name='comments' />
		</div>
	</article>
</BaseLayout>

<script>
	const fnObserver = () => {
		function handleIntersection(
			entries: IntersectionObserverEntry[],
			observer: IntersectionObserver
		) {
			entries.forEach((entry) => {
				const index = document.querySelector(`aside a[href="#${entry.target.id}"]`)
				if (entry.isIntersecting) {
					index?.classList.remove('bg-slate-200', 'dark:bg-slate-800')
					index?.classList.add('bg-blue', 'text-white', 'font-bold')
				} else {
					index?.classList.add('bg-slate-200', 'dark:bg-slate-800')
					index?.classList.remove('bg-blue', 'text-white', 'font-bold')
				}
			})
		}
		const headings = document.querySelectorAll(
			'div.prose h1, div.prose h2, div.prose h3, div.prose h4, div.prose h5, div.prose h6'
		)
		const observer = new IntersectionObserver(handleIntersection, {
			root: null,
			rootMargin: '15% 0px 0% 0px',
			threshold: 1
		})
		headings.forEach((h) => observer.observe(h))
	}
	fnObserver()
	document.addEventListener('astro:after-swap', fnObserver)
</script>
