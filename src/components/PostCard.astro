---
import { siteConfig } from '@/data/site.config'

const { title, heroImage, category, readTime, slug } = Astro.props

const authorName = siteConfig.author
const initials = authorName
	.split(' ')
	.map((n: string) => n[0])
	.join('')
	.toUpperCase()
	.slice(0, 2)
---

<article class='flex flex-col gap-3 group'>
	<a class='relative overflow-hidden rounded-2xl block aspect-[4/3]' href={`/post/${slug}/`}>
		<img
			src={heroImage}
			width='600'
			height='400'
			class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-300'
			alt={`img of ${title}`}
			loading='lazy'
		/>
	</a>

	<div class='flex flex-col gap-2 px-1'>
		<span
			class='inline-block self-start bg-orange-100 dark:bg-orange-900/40 text-orange-600 dark:text-orange-400 text-xs font-semibold px-3 py-1 rounded-full capitalize'
		>
			{category}
		</span>

		<a
			href={`/post/${slug}/`}
			class='text-lg font-bold text-gray-900 dark:text-white leading-snug hover:text-blue dark:hover:text-blue-light transition-colors line-clamp-2'
		>
			{title}
		</a>

		<div class='flex items-center gap-2'>
			<div
				class='w-6 h-6 rounded-full bg-blue flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0'
			>
				{initials}
			</div>
			<span class='text-sm text-gray-500 dark:text-gray-400'>By {authorName}</span>
			{readTime && <span class='text-sm text-gray-400 dark:text-gray-500 ml-auto'>{readTime}</span>}
		</div>
	</div>
</article>
