---
const currentPath = Astro.url.pathname
const isHome = currentPath === '/'
const isTags = currentPath.startsWith('/tags')
---

<nav
	class='fixed bottom-0 left-0 right-0 z-50 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 flex items-center justify-around py-2 md:hidden pb-safe'
>
	<!-- Home -->
	<a
		href='/'
		aria-label='Home'
		class={`flex flex-col items-center gap-0.5 px-4 py-1 ${isHome ? 'text-blue' : 'text-gray-400 dark:text-gray-500'}`}
	>
		<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor' class='w-6 h-6'>
			<path
				d='M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z'
			></path>
			<path
				d='M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z'
			></path>
		</svg>
	</a>

	<!-- Search / Tags -->
	<a
		href='/tags'
		aria-label='Browse tags'
		class={`flex flex-col items-center gap-0.5 px-4 py-1 ${isTags ? 'text-blue' : 'text-gray-400 dark:text-gray-500'}`}
	>
		<svg
			xmlns='http://www.w3.org/2000/svg'
			fill='none'
			viewBox='0 0 24 24'
			stroke-width='1.8'
			stroke='currentColor'
			class='w-6 h-6'
		>
			<path
				stroke-linecap='round'
				stroke-linejoin='round'
				d='M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z'></path>
		</svg>
	</a>

	<!-- RSS / Archive -->
	<a
		href='/rss.xml'
		aria-label='RSS Feed'
		class='flex flex-col items-center gap-0.5 px-4 py-1 text-gray-400 dark:text-gray-500'
	>
		<svg
			xmlns='http://www.w3.org/2000/svg'
			fill='none'
			viewBox='0 0 24 24'
			stroke-width='1.8'
			stroke='currentColor'
			class='w-6 h-6'
		>
			<path
				stroke-linecap='round'
				stroke-linejoin='round'
				d='M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z'
			></path>
		</svg>
	</a>

	<!-- Theme toggle placeholder (person icon) -->
	<button
		id='bottom-nav-theme'
		aria-label='Toggle theme'
		class='flex flex-col items-center gap-0.5 px-4 py-1 text-gray-400 dark:text-gray-500'
	>
		<svg
			xmlns='http://www.w3.org/2000/svg'
			fill='none'
			viewBox='0 0 24 24'
			stroke-width='1.8'
			stroke='currentColor'
			class='w-6 h-6 block dark:hidden'
		>
			<path
				stroke-linecap='round'
				stroke-linejoin='round'
				d='M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z'
			></path>
		</svg>
		<svg
			xmlns='http://www.w3.org/2000/svg'
			fill='none'
			viewBox='0 0 24 24'
			stroke-width='1.8'
			stroke='currentColor'
			class='w-6 h-6 hidden dark:block'
		>
			<path
				stroke-linecap='round'
				stroke-linejoin='round'
				d='M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z'
			></path>
		</svg>
	</button>
</nav>

<script>
	const btn = document.getElementById('bottom-nav-theme')
	btn?.addEventListener('click', () => {
		const html = document.documentElement
		const isDark = html.classList.contains('dark')
		html.classList.toggle('dark', !isDark)
		localStorage.setItem('theme', isDark ? 'light' : 'dark')
	})
</script>
