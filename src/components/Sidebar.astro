---
import { getBlogCategories, getBlogPosts } from '@/utils/blog'
import { siteConfig } from '@/data/site.config'

const categories = await getBlogCategories()
const recentPosts = await getBlogPosts(4)

// Generate author initials from siteConfig.author
const authorName = siteConfig.author
const initials = authorName
	.split(' ')
	.map((n: string) => n[0])
	.join('')
	.toUpperCase()
	.slice(0, 2)
---

<aside class='flex flex-col gap-4 w-full'>
	<!-- Trending Topics -->
	<div class='border border-gray-200 dark:border-gray-700 rounded-2xl p-5'>
		<h3 class='font-bold text-gray-900 dark:text-white mb-1 text-base'>Trending Topics</h3>
		<ul class='divide-y divide-gray-100 dark:divide-gray-700/60'>
			{
				categories.slice(0, 4).map((category: string) => (
					<li>
						<a
							href={`/category/${encodeURIComponent(category.toLowerCase())}/1`}
							class='block py-3 text-gray-600 dark:text-gray-300 hover:text-blue dark:hover:text-blue-light text-sm transition-colors capitalize'
						>
							{category}
						</a>
					</li>
				))
			}
		</ul>
	</div>

	<!-- Recommended Writers -->
	<div class='border border-gray-200 dark:border-gray-700 rounded-2xl p-5'>
		<h3 class='font-bold text-gray-900 dark:text-white mb-3 text-base'>Recommended Writers</h3>
		<ul class='flex flex-col gap-3'>
			<li class='flex items-center gap-3'>
				<div
					class='w-9 h-9 rounded-full bg-blue flex items-center justify-center text-white text-xs font-bold flex-shrink-0'
				>
					{initials}
				</div>
				<span class='text-sm text-gray-700 dark:text-gray-300 font-medium'>{authorName}</span>
			</li>
		</ul>
	</div>
</aside>
