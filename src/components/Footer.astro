---
import { siteConfig } from '@/site-config'

const today = new Date()
---

<footer class='flex justify-center items-center w-full px-16 h-28 border-t-2'>
	&copy; {today.getFullYear()}
	<a
		href='https://www.linkedin.com/in/abdelkouddouss-mekkaoui/'
		target='_blank'
		rel='noopener noreferrer'
		class='ml-1 text-blue hover:text-blue-light dark:text-blue-light dark:hover:text-blue transition-colors hover:underline'
	>
		{siteConfig.author}</a
	>. All rights reserved.
</footer>
