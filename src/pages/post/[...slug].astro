---
import BlogPost from '@/layouts/BlogPost'
import Share from '@/components/Share'
import ListRelatedPosts from '@/components/ListRelatedPosts'
import Disqus from '@/components/Disqus'
import { disqusConfig } from '@/data/disqus.config'
import { getBlogPosts, getBlogPostBySlug } from '@/utils/blog'
import type { BlogPost as BlogPostType } from '@/utils/blog'
import { marked } from 'marked'

export async function getStaticPaths() {
	const posts = await getBlogPosts()
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { slug: post.slug }
	}))
}

const { slug } = Astro.props
const post = await getBlogPostBySlug(slug)

if (!post) {
	return Astro.redirect('/404')
}

const allPosts = await getBlogPosts()
const MAX_POSTS = 3
const lowercaseTags = post.tags.map((t) => t.toLowerCase())
const relatedPosts = allPosts
	.filter(
		(p) => p.slug !== post.slug && p.tags.some((t) => lowercaseTags.includes(t.toLowerCase()))
	)
	.slice(0, MAX_POSTS)

const htmlContent = await marked(post.body)
const disqusEnabled = disqusConfig.enabled
---

<BlogPost
	title={post.title}
	description={post.description}
	pubDate={post.pubDate}
	heroImage={post.heroImage}
	category={post.category}
	readTime={post.readTime}
>
	<Fragment set:html={htmlContent} />

	<Share slot='share' />

	<ListRelatedPosts slot='related' posts={relatedPosts} />

	{disqusEnabled && <Disqus slot='comments' />}

	<div slot='comments' class='mt-8'>
		<h2 class='font-bold text-lg text-gray-900 dark:text-white mb-4'>Comments</h2>
		<div
			class='flex gap-3 items-center border border-gray-200 dark:border-gray-700 rounded-2xl p-3'
		>
			<input
				type='text'
				placeholder='Add a comment...'
				class='flex-1 bg-transparent text-sm text-gray-700 dark:text-gray-300 placeholder-gray-400 outline-none'
			/>
			<button
				class='text-sm font-semibold text-gray-500 dark:text-gray-400 hover:text-blue dark:hover:text-blue-light transition-colors'
			>
				Post
			</button>
		</div>
	</div>
</BlogPost>
